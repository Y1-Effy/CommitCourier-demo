# PostgreSQL connection string (Neon / Supabase / Railway / local).
# Example (Neon): postgres://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgres://postgres:postgres@localhost:5432/commitcourier_demo

# Public base URL the dispatcher delivers webhooks to (this site's own receiver).
# Local dev: http://127.0.0.1:8787  |  Production: https://your-deploy-url
# (use 127.0.0.1 not localhost locally — localhost resolves to IPv6 ::1 first)
PUBLIC_BASE_URL=http://127.0.0.1:8787

# Demo signing secret (Standard Webhooks). Must be "whsec_" + base64 (per the spec).
# Generate your own with: node -e "import('commitcourier').then(m=>console.log('whsec_'+m.generateSecretKey()))"
DEMO_WEBHOOK_SECRET=whsec_MfKQ9r8GKYqrTwjUPD8ILPZIo2LaLaSw

# Server port (the integrated Node app: API + receiver + static frontend).
PORT=8787

# System heartbeat: a low-frequency self-delivery that keeps the demo visibly "alive" and proves the
# dispatcher keeps running. Counted separately (demo_heartbeat), never mixed into the demo metrics.
# HEARTBEAT_INTERVAL_MS: milliseconds between beats (default 60000; set 0 to disable entirely).
HEARTBEAT_INTERVAL_MS=60000
# HEARTBEAT_FLAKY_EVERY: fault-injection knob — every Nth heartbeat is deliberately failed to
#   demonstrate retry -> DLQ. Left at 0 (OFF) on purpose: the heartbeat runs unattended, so a visitor
#   can't tell an injected failure from a real one — it just reads as "this site's deliveries are
#   failing" and hurts trust. Keep it 0 for the public site; only raise it (e.g. 10) for a controlled,
#   clearly-labelled chaos demo. (retry -> DLQ is already shown, on purpose, in the interactive demo.)
HEARTBEAT_FLAKY_EVERY=0
