# PostgreSQL connection string (Neon / Supabase / Railway / local).
# Example (Neon): postgres://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgres://postgres:postgres@localhost:5432/commitcourier_demo

# Public base URL the dispatcher delivers webhooks to (this site's own receiver).
# Local dev: http://127.0.0.1:8787  |  Production: https://your-deploy-url
# (use 127.0.0.1 not localhost locally — localhost resolves to IPv6 ::1 first)
PUBLIC_BASE_URL=http://127.0.0.1:8787

# Demo signing secret (Standard Webhooks). Must be "whsec_" + base64 (per the spec).
# Generate your own with: node -e "import('commitcourier').then(m=>console.log('whsec_'+m.generateSecretKey()))"
DEMO_WEBHOOK_SECRET=whsec_MfKQ9r8GKYqrTwjUPD8ILPZIo2LaLaSw

# Server port (the integrated Node app: API + receiver + static frontend).
PORT=8787
