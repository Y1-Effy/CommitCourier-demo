{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "db-up",
      "type": "npm",
      "script": "db:up",
      "problemMatcher": []
    },
    {
      "label": "migrate",
      "type": "npm",
      "script": "migrate",
      "problemMatcher": []
    },
    {
      "label": "db-ready",
      "dependsOrder": "sequence",
      "dependsOn": ["db-up", "migrate"],
      "problemMatcher": []
    },
    {
      "label": "vite-dev",
      "type": "npm",
      "script": "dev:web",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "ready in"
        }
      }
    }
  ]
}
